export INFRA_CLUSTER_SECRET_BASE_NAME="external-infra-kubeconfig"
export INFRA_CLUSTER_SECRET_NAME="external-infra-kubeconfig"   # overridden per cluster at runtime
export INFRA_CLUSTER_SECRET_NAMESPACE="capk-system"

export CONTROL_PLANE_SERVICE_TYPE="LoadBalancer"
# CONTROL_PLANE_ENDPOINT_IP must be set per cluster – do NOT hardcode here.
# Pass it as an environment variable or via make endpoint-ip=<IP>
# Example: export CONTROL_PLANE_ENDPOINT_IP="10.10.10.50"
export CONTROL_PLANE_ENDPOINT_PORT="6443"

# KUBEVIRT_VM_NAMESPACE is derived from the cluster namespace at runtime.
# It is automatically set to the value of NAMESPACE (= cluster-name by default).
# Do NOT hardcode here.

export VM_IMAGE_URL="quay.io/capk/ubuntu-2404-container-disk:v1.33.5"
# export VM_IMAGE_URL="quay.io/capk/ubuntu-2404-container-disk:v1.34.1"

export CONTROL_PLANE_CPU_CORES="2"
export CONTROL_PLANE_MEMORY="4Gi"

export WORKER_CPU_CORES="2"
export WORKER_MEMORY="4Gi"
